# Groq API key - required. Get one for free from https://console.groq.com/keys
GROQ_API_KEY=gsk-your-groq-api-key-here

# Model used for skill extraction and verdict generation.
# See https://console.groq.com/docs/models for the current list.
# "llama-3.3-70b-versatile" (default) is a strong all-round choice;
# "llama-3.1-8b-instant" is even faster if you want lower latency.
GROQ_MODEL=llama-3.3-70b-versatile

# Comma-separated list of origins allowed to call this API.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Max upload size per file, in megabytes.
MAX_UPLOAD_MB=10
